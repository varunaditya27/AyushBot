\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:architecture}{{1}{11}{AyushBot Five-Layer Offline-First Architecture. Each layer functions independently when upper layers are unavailable. Gradient updates (not raw data) flow upward; model updates flow downward. Async sync enables delay-tolerant operation matching rural connectivity patterns}{figure.caption.1}{}}

# Optional path to a YAML file. Relative paths are resolved from the repo root.
AYUSHBOT_CONFIG=backend/config.yaml

# Common overrides. Never commit real credentials or private key material.
AYUSHBOT_API_HOST=127.0.0.1
AYUSHBOT_API_PORT=8000
AYUSHBOT_DB_PATH=var/ayushbot.db
AYUSHBOT_REDIS_ENABLED=false
AYUSHBOT_REDIS_URL=redis://127.0.0.1:6379/0
AYUSHBOT_MQTT_ENABLED=false
AYUSHBOT_MQTT_HOST=127.0.0.1
AYUSHBOT_MQTT_PORT=1883
AYUSHBOT_MQTT_TLS_ENABLED=false
AYUSHBOT_MQTT_CA_CERT_PATH=
AYUSHBOT_MQTT_CLIENT_CERT_PATH=
AYUSHBOT_MQTT_CLIENT_KEY_PATH=
AYUSHBOT_RAG_INDEX_DIR=backend/rag/index
AYUSHBOT_RAG_MODEL_DIR=models/rag/biencoder
AYUSHBOT_LLM_MODEL_PATH=models/llm/model.gguf
AYUSHBOT_XGB_MODEL_PATH=models/triage_xgb.json
AYUSHBOT_XGB_METADATA_PATH=models/triage_xgb.metadata.json
AYUSHBOT_PRETRIAGE_RULES_PATH=data/reference/pretriage_rules.json
AYUSHBOT_WHO_WAZ_REFERENCE_PATH=data/reference/who_weight_for_age_lms.json
AYUSHBOT_FL_SERVER=127.0.0.1:8080

# Set these only in a local secret manager or untracked environment file.
AYUSHBOT_MQTT_USERNAME=
AYUSHBOT_MQTT_PASSWORD=
AYUSHBOT_JWT_PRIVATE_KEY_PATH=
AYUSHBOT_JWT_PUBLIC_KEY_PATH=
AYUSHBOT_JWT_ISSUER=ayushbot-phc-gateway
AYUSHBOT_JWT_AUDIENCE=ayushbot-tablet
AYUSHBOT_JWT_ACTIVE_KID=gateway-1
AYUSHBOT_API_TLS_CERT_PATH=
AYUSHBOT_API_TLS_KEY_PATH=

# =============================================================================
# AyushBot Cloud — Development Environment Configuration
# =============================================================================
#
# This file is for LOCAL DEVELOPMENT ONLY
# DO NOT use in production — use .env.prod instead
# DO NOT commit to version control
#
# =============================================================================

# PostgreSQL — Development Credentials
POSTGRES_USER=ayushbot
POSTGRES_PASSWORD=dev_password_change_me
POSTGRES_DB=ayushbot_cloud

# InfluxDB — Development Credentials
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=admin_dev_password
INFLUXDB_DB=ayushbot
INFLUXDB_TOKEN=dev_token_12345
INFLUXDB_ORG=ayushbot
INFLUXDB_BUCKET=ayushbot

# Federated Learning Configuration
FL_MIN_CLIENTS=2
FL_STRATEGY=FedAvg
FL_ROUNDS=3

# TLS Configuration — Disabled for local development
ENABLE_TLS=false
CERTFILE=/app/certs/server.crt
KEYFILE=/app/certs/server.key

# Logging — Enable DEBUG for development
LOG_LEVEL=DEBUG

# API Configuration
API_RATE_LIMIT=1000

# Dashboard Configuration
STREAMLIT_THEME=light

# Cloud Storage — Disabled for development
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=dev_key
AWS_SECRET_ACCESS_KEY=dev_secret
S3_BUCKET=ayushbot-cloud-models-dev

# Notifications — Disabled for development
SMTP_SERVER=localhost
SMTP_PORT=1025
SMTP_USER=dev@ayushbot.io
SMTP_PASSWORD=dev
ALERT_EMAIL=dev@ayushbot.io

# Security — Development Keys (NOT for production)
API_SECRET_KEY=dev_secret_key_not_for_production
CORS_ORIGINS=http://localhost:3000,http://localhost:8501,http://127.0.0.1:3000,http://127.0.0.1:8080

# Environment Type
ENVIRONMENT=development

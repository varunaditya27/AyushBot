# =============================================================================
# AyushBot Cloud — Environment Configuration Template
# =============================================================================
#
# COPY THIS FILE TO .env.dev (development) or .env.prod (production)
# and fill in the required values.
#
# DO NOT commit .env or .env.prod to version control (add to .gitignore)
#
# =============================================================================

# =========================================================================
# PostgreSQL Configuration
# =========================================================================
POSTGRES_USER=ayushbot
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=ayushbot_cloud

# =========================================================================
# InfluxDB Configuration
# =========================================================================
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=change_me_in_production
INFLUXDB_DB=ayushbot
INFLUXDB_TOKEN=your_influxdb_token_here
INFLUXDB_ORG=ayushbot
INFLUXDB_BUCKET=ayushbot

# =========================================================================
# Federated Learning Configuration
# =========================================================================
FL_MIN_CLIENTS=3
FL_STRATEGY=FedAvg
FL_ROUNDS=10

# =========================================================================
# TLS/mTLS Configuration
# =========================================================================
ENABLE_TLS=false
CERTFILE=/app/certs/server.crt
KEYFILE=/app/certs/server.key

# =========================================================================
# Logging Configuration
# =========================================================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =========================================================================
# API Configuration
# =========================================================================
# API rate limiting (requests per minute)
API_RATE_LIMIT=60

# =========================================================================
# Dashboard Configuration
# =========================================================================
# Streamlit theme (light, dark)
STREAMLIT_THEME=light

# =========================================================================
# Cloud Storage (Optional — for model backup)
# =========================================================================
# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=ayushbot-cloud-models

# Google Cloud Storage
GCS_PROJECT_ID=your_gcp_project
GCS_BUCKET=ayushbot-cloud-models
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcs-key.json

# =========================================================================
# Notification Configuration (Optional)
# =========================================================================
# Email alerts for critical events
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL=ops@ayushbot.io

# =========================================================================
# Monitoring & Analytics (Optional)
# =========================================================================
# Sentry for error tracking
SENTRY_DSN=

# New Relic for performance monitoring
NEW_RELIC_API_KEY=

# =========================================================================
# Security
# =========================================================================
# API secret key for JWT signing
API_SECRET_KEY=your_secret_key_change_in_production

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8501,http://127.0.0.1:3000

# =========================================================================
# Environment Type
# =========================================================================
# Options: development, staging, production
ENVIRONMENT=development
